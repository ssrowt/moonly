# ─── Telegram ────────────────────────────────────────────────────────────────
# Get from @BotFather
BOT_TOKEN=your_bot_token_here

# Your bot's username (without @), used for referral links
BOT_USERNAME=moonlybot

# Webhook URL for production (your backend's public URL)
# Leave empty in development — polling mode is used automatically
WEBHOOK_URL=https://your-backend.railway.app

# ─── Frontend ────────────────────────────────────────────────────────────────
# Public URL of the Mini App frontend (must be HTTPS for Telegram)
FRONTEND_URL=https://your-username.github.io/moonly-app

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Signals API ─────────────────────────────────────────────────────────────
# URL of the moonly-signals Python service
# Local dev: http://localhost:8000
# Production: https://your-signals-service.onrender.com
SIGNALS_API_URL=http://localhost:8000

# ─── Security ────────────────────────────────────────────────────────────────
# Random secret key for admin API endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=your_random_admin_key_here
